# ========================================
# notification-api Configuration
# ========================================

# Server Configuration
SERVER_PORT=8080

# API Authentication
# IMPORTANTE: Gere uma chave segura para produção
NOTIFICATION_API_KEY=sk_prod_xyz_change_me_in_production

# Notification Service URL
# Apontará para seu notification-service em produção
NOTIFICATION_SERVICE_URL=https://notification-service.seu-dominio.com

# Timeout (ms) para chamadas ao notification-service
NOTIFICATION_TIMEOUT_MS=5000

# ========================================
# DEPLOYMENT INFO
# ========================================
# Para Railway: crie um .env na raiz com estas variáveis
# Para Render/Fly.io: configure as variáveis nas settings do app
# ========================================
